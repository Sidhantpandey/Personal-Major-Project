# ──────────────────────────────────────────────────────────────────────────────
# Plant Disease Detection API – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (asyncpg driver required)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/plant_disease_db

# JWT secret – generate a strong value with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-very-long-random-secret-key

# JWT algorithm (do not change unless you know what you're doing)
ALGORITHM=HS256

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Set to True to enable SQLAlchemy query logging (dev only)
DEBUG=False

# Comma-separated CORS origins (use ["*"] for dev, explicit URLs for prod)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]
